# Buildium MCP Server configuration
# Authentication is via API-key headers (x-buildium-client-id /
# x-buildium-client-secret). There is no OAuth token exchange.

# API base URL WITHOUT the /v1 suffix (the SDK appends /v1 to each path).
#   Production: https://api.buildium.com
#   Sandbox:    https://apisandbox.buildium.com
#   Local mock: http://127.0.0.1:8080
BUILDIUM_BASE_URL=https://apisandbox.buildium.com

# API key credentials (create these in Buildium under API settings).
BUILDIUM_CLIENT_ID=your-client-id-here
BUILDIUM_CLIENT_SECRET=your-client-secret-here

# Optional: comma-separated tool categories to enable (default: all).
# BUILDIUM_CATEGORIES=associations,leases,rentals

# Optional: bearer token for MCP header-auth passthrough. When set, MCP
# clients must send "Authorization: ******" to use the server.
# BUILDIUM_MCP_AUTH_TOKEN=your-shared-secret
