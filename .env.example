# Buildium MCP Server configuration
# Authentication is via API-key headers (x-buildium-client-id /
# x-buildium-client-secret). There is no OAuth token exchange.

# API base URL WITHOUT the /v1 suffix (the SDK appends /v1 to each path).
#   Production: https://api.buildium.com
#   Sandbox:    https://apisandbox.buildium.com
#   Local mock: http://127.0.0.1:8080
BUILDIUM_BASE_URL=https://apisandbox.buildium.com

# API key credentials (create these in Buildium under API settings).
BUILDIUM_CLIENT_ID=your-client-id-here
BUILDIUM_CLIENT_SECRET=your-client-secret-here

# Optional: comma-separated tool categories to enable (default: all).
# BUILDIUM_CATEGORIES=associations,leases,rentals

# Optional: bearer token for MCP header-auth passthrough. When set, MCP
# clients must send "Authorization: ******" to use the server.
# BUILDIUM_MCP_AUTH_TOKEN=your-shared-secret

# --- Transport --------------------------------------------------------------
# 'stdio' (default) embeds the server in a local MCP client (Claude Desktop,
# Cursor). 'http' serves the Streamable HTTP transport over the network so
# remote clients (e.g. the browser extension in extension/) can connect.
# BUILDIUM_TRANSPORT=http
# BUILDIUM_HOST=0.0.0.0
# BUILDIUM_PORT=8000
# BUILDIUM_MCP_PATH=/mcp

# --- Microsoft Entra ID (Azure AD) JWT auth --------------------------------
# When tenant + audience are set, MCP requests must carry a valid Entra access
# token (verified against Entra's JWKS: signature, iss, aud, exp, scopes).
# BUILDIUM_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# BUILDIUM_ENTRA_AUDIENCE=api://<api-app-client-id>
# Optional overrides (otherwise derived from the tenant ID):
# BUILDIUM_ENTRA_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# BUILDIUM_ENTRA_JWKS_URI=https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys
# Optional required scopes (comma-separated):
# BUILDIUM_ENTRA_REQUIRED_SCOPES=MCP.Access

# --- CORS (HTTP transport only) --------------------------------------------
# Comma-separated allowed origins for browser clients. Use the extension's
# origin(s); '*' allows any origin (credentials are then disabled).
# BUILDIUM_CORS_ALLOW_ORIGINS=chrome-extension://<extension-id>,moz-extension://<extension-id>
