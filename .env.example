# Buildium MCP Server configuration
# Authentication is via API-key headers (x-buildium-client-id /
# x-buildium-client-secret). There is no OAuth token exchange.

# API base URL WITHOUT the /v1 suffix (the SDK appends /v1 to each path).
#   Production: https://api.buildium.com
#   Sandbox:    https://apisandbox.buildium.com
#   Local mock: http://127.0.0.1:8080
BUILDIUM_BASE_URL=https://apisandbox.buildium.com

# API key credentials (create these in Buildium under API settings).
BUILDIUM_CLIENT_ID=your-client-id-here
BUILDIUM_CLIENT_SECRET=your-client-secret-here

# Optional: comma-separated tool categories to enable (default: all).
# BUILDIUM_CATEGORIES=associations,leases,rentals

# Optional: bearer token for MCP header-auth passthrough. When set, MCP
# clients must send "Authorization: ******" to use the server.
# BUILDIUM_MCP_AUTH_TOKEN=your-shared-secret

# ---------------------------------------------------------------------------
# Security guardrails & roles (all optional; defaults keep every tool enabled)
# ---------------------------------------------------------------------------
# Role controlling which tools are permitted:
#   readonly  - only list_*/get_* tools
#   operator  - reads + non-sensitive writes (no bills/bank/GL/payments)
#   admin     - all tools (default)
#   custom    - shaped entirely by the allow/deny lists below
# BUILDIUM_ROLE=admin

# Global kill switch: disable ALL mutating tools regardless of role.
# BUILDIUM_READONLY=false

# Disable financially sensitive tools (bills, bank accounts, general ledger,
# payments, file upload/download URLs).
# BUILDIUM_BLOCK_SENSITIVE=false

# Fine-grained allow/deny lists by tool name (deny always wins). When ALLOW is
# set it acts as a strict whitelist.
# BUILDIUM_ALLOW_TOOLS=list_leases,get_lease
# BUILDIUM_DENY_TOOLS=create_bill,create_bill_payment

# Cap tool invocations per rolling 60-second window (0 = unlimited).
# BUILDIUM_RATE_LIMIT_PER_MINUTE=0

# ---------------------------------------------------------------------------
# Audit trail
# ---------------------------------------------------------------------------
# Where audit events go: 'log' (stderr JSON, default), 'file', or 'none'.
# BUILDIUM_AUDIT_SINK=log
# BUILDIUM_AUDIT_FILE=/var/log/buildium-mcp/audit.log

# ---------------------------------------------------------------------------
# Tuning (optional; sensible defaults are used when unset)
# ---------------------------------------------------------------------------
# BUILDIUM_MAX_RETRIES=3
# BUILDIUM_REQUEST_TIMEOUT_SECONDS=30
# BUILDIUM_MAX_PAGE_LIMIT=1000
# BUILDIUM_DEFAULT_PAGE_LIMIT=100
