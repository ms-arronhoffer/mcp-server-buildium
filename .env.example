# Buildium MCP Server configuration
# Authentication is via API-key headers (x-buildium-client-id /
# x-buildium-client-secret). There is no OAuth token exchange.

# API base URL WITHOUT the /v1 suffix (the SDK appends /v1 to each path).
#   Production: https://api.buildium.com
#   Sandbox:    https://apisandbox.buildium.com
#   Local mock: http://127.0.0.1:8080
BUILDIUM_BASE_URL=https://apisandbox.buildium.com

# API key credentials (create these in Buildium under API settings).
BUILDIUM_CLIENT_ID=your-client-id-here
BUILDIUM_CLIENT_SECRET=your-client-secret-here

# Optional: comma-separated tool categories to enable (default: all).
# BUILDIUM_CATEGORIES=associations,leases,rentals

# Optional: bearer token for MCP header-auth passthrough. When set, MCP
# clients must send "Authorization: ******" to use the server.
# BUILDIUM_MCP_AUTH_TOKEN=your-shared-secret

# --- Transport --------------------------------------------------------------
# 'stdio' (default) embeds the server in a local MCP client (Claude Desktop,
# Cursor). 'http' serves the Streamable HTTP transport over the network so
# remote clients (e.g. the browser extension in extension/) can connect.
# BUILDIUM_TRANSPORT=http
# BUILDIUM_HOST=0.0.0.0
# BUILDIUM_PORT=8000
# BUILDIUM_MCP_PATH=/mcp

# --- Microsoft Entra ID (Azure AD) JWT auth --------------------------------
# When tenant + audience are set, MCP requests must carry a valid Entra access
# token (verified against Entra's JWKS: signature, iss, aud, exp, scopes).
# BUILDIUM_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
# BUILDIUM_ENTRA_AUDIENCE=api://<api-app-client-id>
# Optional overrides (otherwise derived from the tenant ID):
# BUILDIUM_ENTRA_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# BUILDIUM_ENTRA_JWKS_URI=https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys
# Optional required scopes (comma-separated):
# BUILDIUM_ENTRA_REQUIRED_SCOPES=MCP.Access
# Optional per-user tool scoping: map Entra App Role values (token 'roles' claim;
# group object IDs also match) to a coarse role (readonly/operator/admin).
# Callers matching no mapped role are denied all tools.
# BUILDIUM_ENTRA_ROLE_POLICY_MAP={"Buildium.Admin":"admin","Buildium.Operator":"operator","Buildium.ReadOnly":"readonly"}

# --- Dev auth bypass (NON-PRODUCTION) --------------------------------------
# Disables ALL authentication on /mcp, /chat and /capabilities so you can test
# locally against the mock API without an Entra tenant or token. NEVER enable
# this on a network-reachable or production deployment.
# BUILDIUM_DEV_AUTH_BYPASS=true

# ---------------------------------------------------------------------------
# Server-side LLM assistant (/chat + /capabilities)
# ---------------------------------------------------------------------------
# The assistant runs the tool-calling loop on the server so provider API keys
# stay server-side and are NEVER sent to the browser extension. The extension
# only talks to /chat (streamed over SSE) using the user's Entra token.
#
# *** RECOMMENDED: use the admin UI at /manage/ to configure models and keys ***
# When BUILDIUM_MANAGEMENT_ENABLED=true, open https://<your-server>/manage/ to
# configure LLM providers and model tiers through a web interface. No env vars
# are needed for LLM once the store file has been saved via the admin UI.
#
# LLM config store path (where the admin-UI config is persisted):
# BUILDIUM_LLM_CONFIG_PATH=llm_config.json
# When running via docker-compose, the mcp-server-http service defaults this to
# /app/data/llm_config.json, which is backed by the named `buildium-data` volume
# so web-configured providers/models/keys survive container recreation.
#
# Optional Fernet encryption key for API keys stored in the config file.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this, API keys are stored in plaintext with a startup warning.
# BUILDIUM_LLM_STORE_KEY=<base64-fernet-key>

# ---------------------------------------------------------------------------
# DEPRECATED LLM env vars (use the admin UI at /manage/ instead)
# ---------------------------------------------------------------------------
# These vars are still honoured for backward compatibility: if the config store
# file does not exist yet, the server seeds the store from these values on
# first use. Set them for a one-time migration, then remove them once you have
# saved the config through the admin UI. A DeprecationWarning is logged at
# startup when these are set alongside a non-empty BUILDIUM_LLM_CONFIG_PATH.
#
# Single-provider mode (DEPRECATED — prefer the admin UI):
# BUILDIUM_LLM_PROVIDER=openai     # openai | anthropic | gemini
# BUILDIUM_LLM_MODEL=gpt-4o-mini
# BUILDIUM_LLM_OPENAI_API_KEY=sk-...
# BUILDIUM_LLM_ANTHROPIC_API_KEY=sk-ant-...
# BUILDIUM_LLM_GEMINI_API_KEY=...
#
# Multi-provider router mode (DEPRECATED — prefer the admin UI):
# BUILDIUM_LLM_ROUTER_ENABLED=true
# BUILDIUM_LLM_ROUTER_PROVIDERS=[{"provider":"anthropic","model":"claude-opus-4-5"},{"provider":"openai","model":"gpt-4o"}]
# BUILDIUM_LLM_ROUTER_STRATEGY=classifier
#
# Still useful in all modes:
# BUILDIUM_LLM_ALLOWED_MODELS=gpt-4o-mini,gpt-4o
# BUILDIUM_LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# BUILDIUM_LLM_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# BUILDIUM_LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# BUILDIUM_LLM_SYSTEM_PROMPT=You are a helpful property-management assistant.
# BUILDIUM_LLM_MAX_TOOL_ROUNDS=8

# --- CORS (HTTP transport only) --------------------------------------------
# Comma-separated allowed origins for browser clients. Use the extension's
# origin(s); '*' allows any origin (credentials are then disabled).
# BUILDIUM_CORS_ALLOW_ORIGINS=chrome-extension://<extension-id>,moz-extension://<extension-id>

# ---------------------------------------------------------------------------
# Admin management routes (/manage/*) — admin-only, off by default
# ---------------------------------------------------------------------------
# When enabled, the self-contained admin UI (GET /manage/) and the LLM-config
# routes become available. An admin (a caller whose Entra token maps to the
# coarse 'admin' role via BUILDIUM_ENTRA_ROLE_POLICY_MAP) can additionally invite
# Entra B2B guests with a role and edit user roles — those user-management
# features need the Microsoft Graph settings below. When the Graph settings are
# omitted the server still starts and only the user-management routes are
# disabled (HTTP 502). Gated by the SAME Entra JWT auth as /mcp. All Microsoft
# Graph credentials stay server-side.
# BUILDIUM_MANAGEMENT_ENABLED=true
#
# Microsoft Graph app registration (app-only, client-credentials), required only
# for the user-management routes. Grant the admin-consented application
# permissions: User.Invite.All, AppRoleAssignment.ReadWrite.All,
# Application.Read.All.
# BUILDIUM_GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000   # defaults to ENTRA_TENANT_ID
# BUILDIUM_GRAPH_CLIENT_ID=<graph-app-client-id>
# BUILDIUM_GRAPH_CLIENT_SECRET=<graph-app-client-secret>
# BUILDIUM_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
#
# Object ID of the API app's service principal (enterprise application) — the
# resource that app-role assignments are created on.
# BUILDIUM_ENTRA_API_SERVICE_PRINCIPAL_ID=<service-principal-object-id>
#
# JSON map of coarse role name -> the API app's Entra App Role IDs (GUIDs).
# BUILDIUM_ENTRA_APP_ROLE_ID_MAP={"admin":"<guid>","operator":"<guid>","readonly":"<guid>"}
#
# Optional B2B invitation settings.
# BUILDIUM_MANAGEMENT_INVITE_REDIRECT_URL=https://myapps.microsoft.com
# BUILDIUM_MANAGEMENT_SEND_INVITATION_MESSAGE=true
#
# Prebuilt, preconfigured extension archives served by GET /manage/extension.
# Produce these at release time: run the extension build with your public
# defaults (see extension/README.md), zip dist/chrome -> .zip and dist/firefox
# -> .xpi, and point these at the resulting files. Use ABSOLUTE paths to an
# existing file; the download route returns 503 (naming the resolved path) when
# the file is missing, and a browser is only offered for download when its
# archive actually exists on disk.
# BUILDIUM_MANAGEMENT_EXTENSION_CHROME_PATH=/srv/ext/buildium-mcp-sidebar-chrome.zip
# BUILDIUM_MANAGEMENT_EXTENSION_FIREFOX_PATH=/srv/ext/buildium-mcp-sidebar-firefox.xpi

# ---------------------------------------------------------------------------
# Security guardrails & roles (all optional; defaults keep every tool enabled)
# ---------------------------------------------------------------------------
# Role controlling which tools are permitted:
#   readonly  - only list_*/get_* tools
#   operator  - reads + non-sensitive writes (no bills/bank/GL/payments)
#   admin     - all tools (default)
#   custom    - shaped entirely by the allow/deny lists below
# BUILDIUM_ROLE=admin

# Global kill switch: disable ALL mutating tools regardless of role.
# BUILDIUM_READONLY=false

# Disable financially sensitive tools (bills, bank accounts, general ledger,
# payments, file upload/download URLs).
# BUILDIUM_BLOCK_SENSITIVE=false

# Fine-grained allow/deny lists by tool name (deny always wins). When ALLOW is
# set it acts as a strict whitelist.
# BUILDIUM_ALLOW_TOOLS=list_leases,get_lease
# BUILDIUM_DENY_TOOLS=create_bill,create_bill_payment

# Cap tool invocations per rolling 60-second window (0 = unlimited).
# BUILDIUM_RATE_LIMIT_PER_MINUTE=0

# ---------------------------------------------------------------------------
# Audit trail
# ---------------------------------------------------------------------------
# Where audit events go: 'log' (stderr JSON, default), 'file', or 'none'.
# BUILDIUM_AUDIT_SINK=log
# BUILDIUM_AUDIT_FILE=/var/log/buildium-mcp/audit.log

# ---------------------------------------------------------------------------
# Tuning (optional; sensible defaults are used when unset)
# ---------------------------------------------------------------------------
# BUILDIUM_MAX_RETRIES=3
# BUILDIUM_MAX_PAGE_LIMIT=1000
# BUILDIUM_DEFAULT_PAGE_LIMIT=100

# ---------------------------------------------------------------------------
# AWS SES email dispatch (optional; enables the 'email' tool category)
# ---------------------------------------------------------------------------
# Set BUILDIUM_AWS_SES_SENDER to a verified SES sender address to enable
# send_email / send_email_to_tenant / send_email_to_owner tools. AWS
# credentials stay on the server — the extension never sees them.
#
# Required:
# BUILDIUM_AWS_SES_SENDER=noreply@yourdomain.com
#
# Optional (falls back to IAM role / environment credential chain):
# BUILDIUM_AWS_REGION=us-east-1
# BUILDIUM_AWS_ACCESS_KEY_ID=AKIA...
# BUILDIUM_AWS_SECRET_ACCESS_KEY=...
#
# LocalStack / alternative endpoint (for local testing):
# BUILDIUM_AWS_SES_ENDPOINT_URL=http://localhost:4566
